# Copia este archivo a ".env" (mismo folder que puente.js) y llena tus valores.
# El archivo ".env" NUNCA se sube a git (ya está en .gitignore).

# Puerto serial donde está conectado el ESP32
PUERTO_COM=COM5

# Identificador del camión (debe coincidir con el nodo en Firebase)
CAMION_ID=camion_01

# Tu API key de Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Modelo de Gemini a usar
GEMINI_MODEL=gemini-2.5-flash

# Temperatura de referencia que se le explica a la IA (°C)
TEMP_REFERENCIA_MAX_C=5.5

# Cada cuántos milisegundos, como mínimo, se le pregunta a Gemini
INTERVALO_MINIMO_ANALISIS_MS=8000
